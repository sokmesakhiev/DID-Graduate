{
  "name": "issuer-api",
  "version": "1.0.0",
  "private": true,
  "description": "Issuer backend — Cardano metadata tx writer + Cloud Agent proxy",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@blockfrost/blockfrost-js": "^5.5.0",
    "@meshsdk/core": "^1.7.8",
    "@university-diplomas/common": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
